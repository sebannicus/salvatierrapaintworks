---
import WhatsAppButton from '../ui/WhatsAppButton.astro';

const pasos = [
  {
    numero: '01',
    titulo: 'Envíame tu proyecto',
    descripcion: 'Mándame fotos, videos y medidas de la zona a pintar o del proyecto que quieres realizar.',
  },
  {
    numero: '02',
    titulo: 'Preparo tu cotización',
    descripcion: 'En base a lo que me envíes, elaboro una cotización detallada. Rápida y sin vueltas.',
  },
  {
    numero: '03',
    titulo: 'Agenda una visita (si es necesario)',
    descripcion: 'Si el proyecto lo requiere, coordinamos una visita en terreno sin costo para ajustar los detalles.',
  },
  {
    numero: '04',
    titulo: 'Comenzamos el trabajo',
    descripcion: 'Una vez acordado todo, fijamos fecha de inicio y ejecuto el trabajo personalmente.',
  },
];
---

<section
  id="cotizacion"
  class="section-pad"
  style="background-color: var(--color-bg-dark);"
>
  <div class="max-w-5xl mx-auto px-5">

    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-xs tracking-widest uppercase mb-3" style="color: var(--color-accent); font-family: var(--font-label);">Sin complicaciones</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: var(--font-display); color: var(--color-text-light);">
        ¿Cómo cotizo tu proyecto?
      </h2>
      <p class="text-base max-w-xl mx-auto" style="color: rgba(240,232,212,0.65);">
        El proceso es simple. Sin formularios complicados, sin intermediarios.
      </p>
    </div>

    <!-- Pasos -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-14">
      {pasos.map((paso) => (
        <div
          class="flex gap-5 p-7 rounded-2xl"
          style="background: rgba(255,255,255,0.04); border: 1px solid rgba(166,149,128,0.2);"
        >
          <!-- Número -->
          <div class="flex-shrink-0">
            <span
              class="text-4xl font-black leading-none"
              style="font-family: var(--font-display); color: rgba(166,149,128,0.25);"
            >
              {paso.numero}
            </span>
          </div>
          <!-- Contenido -->
          <div>
            <h3 class="font-semibold text-base mb-2" style="font-family: var(--font-label); color: var(--color-text-light);">
              {paso.titulo}
            </h3>
            <p class="text-sm leading-relaxed" style="color: rgba(240,232,212,0.6);">
              {paso.descripcion}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA central -->
    <div class="flex flex-col items-center gap-4 text-center">
      <p class="text-lg" style="color: rgba(240,232,212,0.75);">
        ¿Tienes un proyecto en mente? Escríbeme ahora.
      </p>
      <WhatsAppButton label="Cotizar mi proyecto por WhatsApp" size="lg" />
      <p class="text-xs" style="color: rgba(166,149,128,0.6); font-family: var(--font-label);">
        Respondo el mismo día · Sin compromiso
      </p>
    </div>
  </div>
</section>
