---
import WhatsAppButton from '../ui/WhatsAppButton.astro';
---

<section
  id="sobre-pablo"
  class="section-pad"
  style="background-color: var(--color-bg-dark);"
>
  <div class="max-w-6xl mx-auto px-5">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Logo / imagen lado izquierdo -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Decorative ring -->
          <div
            class="absolute -inset-4 rounded-full opacity-20"
            style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
          ></div>
          <div
            class="relative w-64 h-64 md:w-80 md:h-80 rounded-full overflow-hidden border-4 shadow-2xl"
            style="border-color: var(--color-accent);"
          >
            <img
              src="/images/logo-salvatierra.jpeg"
              alt="Pablo Salvatierra — Fundador Salvatierra PaintWorks"
              width="320"
              height="320"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Badge Australia -->
          <div
            class="absolute -bottom-4 -right-4 px-4 py-2 rounded-full text-xs font-bold tracking-wide shadow-lg"
            style="background: var(--color-bg); color: var(--color-text-primary); font-family: var(--font-label); border: 2px solid var(--color-accent-mid);"
          >
            🇦🇺 Formado en Australia
          </div>
        </div>
      </div>

      <!-- Texto lado derecho -->
      <div class="flex flex-col gap-6">
        <div>
          <p class="text-xs tracking-widest uppercase mb-3" style="color: var(--color-accent); font-family: var(--font-label);">Quién soy</p>
          <h2 class="text-3xl md:text-4xl font-bold leading-tight mb-6" style="font-family: var(--font-display); color: var(--color-text-light);">
            Soy Pablo Salvatierra,<br/>
            <em class="not-italic" style="color: var(--color-accent-mid);">pintor de oficio</em>
          </h2>
        </div>

        <div class="flex flex-col gap-4 text-base leading-relaxed" style="color: rgba(240,232,212,0.75);">
          <p>
            Tengo más de <strong style="color: var(--color-text-light); font-weight: 700;">10 años de experiencia</strong> en pintura profesional.
            Aprendí en Australia trabajando en casas de alto valor con verdaderos profesionales de la industria — donde la calidad no es opcional.
          </p>
          <p>
            Actualmente realizo trabajos de la más alta calidad tanto en la <strong style="color: var(--color-text-light); font-weight: 700;">Región Metropolitana</strong>
            como en la <strong style="color: var(--color-text-light); font-weight: 700;">Cuarta Región de Coquimbo</strong>.
          </p>
          <p>
            Cada proyecto lo ejecuto <strong style="color: var(--color-text-light);">personalmente</strong>. No subcontrato, no delego.
            Cuando me contratas, es mi mano, mi experiencia y mi reputación lo que está en juego.
          </p>
        </div>

        <!-- Highlights rápidos -->
        <ul class="flex flex-col gap-3 mt-2">
          {[
            'Formado con estándar internacional — Australia',
            'Experto certificado en pintura Airless',
            'Más de 100 proyectos completados',
            'Trato directo: hablas siempre conmigo',
          ].map((item) => (
            <li class="flex items-center gap-3 text-sm" style="color: rgba(240,232,212,0.8);">
              <span class="w-5 h-5 flex-shrink-0 rounded-full flex items-center justify-center" style="background: var(--color-accent); color: var(--color-bg-dark);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              {item}
            </li>
          ))}
        </ul>

        <div class="mt-2">
          <WhatsAppButton label="Contáctame directamente" size="md" />
        </div>
      </div>
    </div>
  </div>
</section>
