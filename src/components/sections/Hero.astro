---
import WhatsAppButton from '../ui/WhatsAppButton.astro';
---

<section
  id="inicio"
  class="relative min-h-screen flex flex-col items-center justify-center text-center px-5 overflow-hidden"
  style="background-color: var(--color-bg-dark);"
>
  <!-- Subtle radial background glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 60% at 50% 40%, #1a2e30 0%, #0E1718 100%);"
  ></div>

  <!-- Decorative top border -->
  <div class="absolute top-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, transparent, var(--color-accent), transparent);"></div>

  <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center gap-8">

    <!-- Logo -->
    <div class="w-36 h-36 md:w-48 md:h-48 rounded-full overflow-hidden border-4 shadow-2xl flex-shrink-0" style="border-color: var(--color-accent);">
      <img
        src="/images/logo-salvatierra.jpeg"
        alt="Salvatierra PaintWork Logo"
        width="192"
        height="192"
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>

    <!-- Badges de credenciales -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium tracking-widest uppercase" style="background: rgba(166,149,128,0.15); border: 1px solid rgba(166,149,128,0.3); color: var(--color-accent-mid); font-family: var(--font-label);">
        +10 Años de Experiencia
      </span>
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium tracking-widest uppercase" style="background: rgba(166,149,128,0.15); border: 1px solid rgba(166,149,128,0.3); color: var(--color-accent-mid); font-family: var(--font-label);">
        Tecnología Airless
      </span>
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium tracking-widest uppercase" style="background: rgba(166,149,128,0.15); border: 1px solid rgba(166,149,128,0.3); color: var(--color-accent-mid); font-family: var(--font-label);">
        IV Región · Coquimbo
      </span>
    </div>

    <!-- Headline -->
    <h1
      class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight"
      style="font-family: var(--font-display); color: var(--color-text-light);"
    >
      Trabajos de Pintura<br/>
      <em class="not-italic" style="color: var(--color-accent-mid);">Fina, Rápidos</em><br/>
      y Detallados
    </h1>

    <!-- Subtítulo -->
    <p
      class="text-lg md:text-xl max-w-xl leading-relaxed"
      style="color: rgba(240,232,212,0.65);"
    >
      Tecnología Airless profesional. Trato directo con el dueño.<br class="hidden md:block"/>
      Excelente relación precio-calidad.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
      <WhatsAppButton label="Solicita tu cotización por WhatsApp" size="lg" />
      <a
        href="#servicios"
        class="text-sm font-medium tracking-wide underline underline-offset-4 transition-opacity hover:opacity-70"
        style="color: var(--color-accent-mid); font-family: var(--font-label);"
      >
        Ver servicios ↓
      </a>
    </div>

    <!-- Stats rápidas -->
    <div class="grid grid-cols-3 gap-8 mt-6 pt-8" style="border-top: 1px solid rgba(166,149,128,0.25);">
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-bold" style="font-family: var(--font-display); color: var(--color-text-light);">+100</p>
        <p class="text-xs mt-1 tracking-widest uppercase" style="color: var(--color-text-secondary); font-family: var(--font-label);">Obras ejecutadas</p>
      </div>
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-bold" style="font-family: var(--font-display); color: var(--color-text-light);">10+</p>
        <p class="text-xs mt-1 tracking-widest uppercase" style="color: var(--color-text-secondary); font-family: var(--font-label);">Años de experiencia</p>
      </div>
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-bold" style="font-family: var(--font-display); color: var(--color-text-light);">1</p>
        <p class="text-xs mt-1 tracking-widest uppercase" style="color: var(--color-text-secondary); font-family: var(--font-label);">Solo el dueño ejecuta</p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce" aria-hidden="true">
    <div class="w-px h-12" style="background: linear-gradient(180deg, rgba(166,149,128,0.6), transparent);"></div>
  </div>
</section>
