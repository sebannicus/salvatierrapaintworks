---
const instaUrl = 'https://instagram.com/salvatierrapaintworks';

const servicios = [
  'Tecnología Airless',
  'Pintura Interior/Exterior',
  'Empastado y Muros',
  'Restauración Humedad',
  'Barnices y Esmaltes',
];

const mosaico = [
  { src: '/images/pintura-oficina-6.webp',  alt: 'Auditorio Santiago College — Resultado' },
  { src: '/images/pintura-edificio-5.webp', alt: 'Motoaventura — Fachada Renovada' },
  { src: '/images/cabaña-6.webp',           alt: 'Barniz Cabaña — Detalle' },
  { src: '/images/techo-lindo-baño-2.webp',  alt: 'Restauración Baño' },
];
---

<section
  id="instagram"
  class="relative overflow-hidden section-pad"
  style="background-color: var(--color-bg);"
>
  <div class="max-w-6xl mx-auto px-5 text-balance">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- ── Columna izquierda: contenido ── -->
      <div class="flex flex-col gap-6 anim-left">

        <!-- Label -->
        <div>
          <p class="text-xs tracking-widest uppercase font-bold mb-3" style="color: var(--color-text-secondary); font-family: var(--font-label);">Nuestra Comunidad</p>
          <h2 class="text-3xl md:text-5xl font-black leading-tight" style="font-family: var(--font-display); color: var(--color-text-primary); letter-spacing: -0.02em;">
            Creciendo con cada<br/>
            <span style="color: var(--color-accent);">proyecto</span> 🖌️✨
          </h2>
        </div>

        <!-- Texto -->
        <div class="space-y-4 text-base md:text-lg leading-relaxed" style="color: var(--color-text-secondary);">
          <p>
            Desde el auditorio del <strong style="color: var(--color-text-primary);">Santiago College</strong> hasta fachadas icónicas como <strong style="color: var(--color-text-primary);">Motoaventura Chile</strong>, 
            cada día más clientes confían en nuestro compromiso con el detalle.
          </p>
          <p>
            Nos llena el corazón ver cómo crece esta comunidad que valora el buen oficio. Seguimos dándolo todo con la misma pasión de siempre.
          </p>
        </div>

        <!-- Servicios chips -->
        <div>
          <p class="text-xs tracking-widest uppercase font-bold mb-3" style="color: var(--color-text-secondary); font-family: var(--font-label);">🛠️ Especialidades</p>
          <div class="flex flex-wrap gap-2">
            {servicios.map((s) => (
              <span
                class="px-4 py-2 rounded-full text-sm font-bold"
                style="background-color: var(--color-bg-surface); border: 1px solid rgba(166,149,128,0.4); color: var(--color-text-primary); font-family: var(--font-label);"
              >
                {s}
              </span>
            ))}
          </div>
        </div>

        <!-- Quote -->
        <blockquote
          class="relative pl-5 text-base md:text-lg italic leading-relaxed"
          style="border-left: 3px solid var(--color-accent); color: var(--color-text-secondary);"
        >
          "Trabajamos con rapidez, calidad y atención al detalle. Nada nos detiene cuando se trata de renovar un espacio." 💪💥
        </blockquote>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={instaUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 px-8 py-5 rounded-full text-base font-bold transition-all duration-200"
            style="background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); color: #fff; font-family: var(--font-label); box-shadow: 0 4px 20px rgba(220,39,67,0.28);"
            onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 32px rgba(220,39,67,0.45)'"
            onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(220,39,67,0.28)'"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            @salvatierrapaintworks
          </a>

          <a
            href={`https://wa.me/56995088570?text=${encodeURIComponent('Hola Salvatierra Paintworks, vi tu página web y me gustaría cotizar un trabajo de pintura')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 px-8 py-5 rounded-full text-base font-bold btn-wa-glow"
            style="background-color: var(--color-wa-green); color: var(--color-bg-dark); font-family: var(--font-label);"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Escríbenos
          </a>
        </div>

      </div>

      <!-- ── Columna derecha: mosaico de fotos ── -->
      <div class="anim-right">
        <div class="grid grid-cols-2 gap-3">
          {mosaico.map((foto, i) => (
            <div
              class="relative overflow-hidden rounded-xl group"
              style="border: 1px solid rgba(166,149,128,0.2);"
            >
              <img
                src={foto.src}
                alt={foto.alt}
                class="w-full h-[200px] md:h-[240px] object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div
                class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4 text-center text-xs font-bold"
                style="background: rgba(14,23,24,0.7); color: var(--color-accent-mid);"
              >
                {foto.alt}
              </div>
            </div>
          ))}
        </div>

        <!-- Tag de credibilidad -->
        <div class="mt-4 flex items-center justify-center gap-2 p-3 rounded-xl" style="background-color: var(--color-bg-surface); border: 1px solid rgba(166,149,128,0.3);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#F59E0B" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <p class="text-xs font-bold" style="color: var(--color-text-secondary); font-family: var(--font-label);">
            Gracias por confiar en Salvatierra Paintworks Co.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
