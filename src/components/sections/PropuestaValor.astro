---
interface Pilar {
  icon: string;
  titulo: string;
  descripcion: string;
}

const pilares: Pilar[] = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    titulo: 'Acabado impecable',
    descripcion: 'Preparación y aplicación cuidadosa en cada superficie. El resultado se nota desde el primer vistazo.',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    titulo: 'Tecnología Airless',
    descripcion: 'Pintura a presión para un finish profesional: parejo, rápido y sin marcas de rodillo.',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    titulo: 'Puntual y ordenado',
    descripcion: 'Llego cuando digo, trabajo limpio y dejo el espacio como lo encontré. Sin sorpresas.',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
    titulo: 'Hablas con quien pinta',
    descripcion: 'No hay intermediarios. Pablo cotiza, Pablo ejecuta. Lo que acordamos es lo que recibes.',
  },
];
---

<section id="propuesta" class="section-pad" style="background-color: var(--color-bg);">
  <div class="max-w-6xl mx-auto px-5">

    <!-- Header sección -->
    <div class="text-center mb-16 reveal">
      <p class="text-xs tracking-widest uppercase mb-3" style="color: var(--color-text-secondary); font-family: var(--font-label);">Cómo trabajo</p>
      <h2 class="text-3xl md:text-4xl font-bold" style="font-family: var(--font-display); color: var(--color-text-primary);">
        Pintura de verdad, sin vueltas
      </h2>
    </div>

    <!-- Grid de pilares -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {pilares.map((pilar, i) => (
        <div
          class={`flex flex-col gap-4 p-8 rounded-2xl transition-transform hover:-translate-y-1 duration-200 reveal delay-${i + 1}`}
          style="background-color: var(--color-bg-surface); border: 1px solid var(--color-accent-mid);"
        >
          <!-- Ícono -->
          <div class="w-14 h-14 rounded-xl flex items-center justify-center" style="background-color: var(--color-bg-dark); color: var(--color-accent-mid);">
            <Fragment set:html={pilar.icon} />
          </div>

          <!-- Título + descripción -->
          <div>
            <h3 class="font-semibold text-base mb-1" style="font-family: var(--font-label); color: var(--color-text-primary);">
              {pilar.titulo}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              {pilar.descripcion}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
