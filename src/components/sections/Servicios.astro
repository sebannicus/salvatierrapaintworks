---
interface Servicio {
  icon: string;
  titulo: string;
  descripcion: string;
}

const servicios: Servicio[] = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    titulo: 'Pintura Interior y Exterior',
    descripcion: 'Muros, cielos, fachadas y recintos. Acabado profesional con tecnología Airless para resultados uniformes y duraderos.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>`,
    titulo: 'Pintura de Oficinas',
    descripcion: 'Espacios de trabajo renovados con mínima interrupción. Pintamos en tiempos acordados para no afectar tu operación.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
    titulo: 'Empastados',
    descripcion: 'Preparación y nivelación de superficies para lograr un terminado liso y profesional antes de pintar.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
    titulo: 'Reparación de Muros',
    descripcion: 'Sellado de grietas, fisuras y daños estructurales menores. Dejamos el muro como nuevo antes de aplicar la pintura.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 007-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 007 7z"/></svg>`,
    titulo: 'Eliminación de Humedad',
    descripcion: 'Tratamiento especializado para muros con humedad, manchas de salitre y hongos. Solución permanente, no cosmética.',
  },
];
---

<section id="servicios" class="section-pad" style="background-color: var(--color-bg);">
  <div class="max-w-6xl mx-auto px-5">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <p class="text-xs tracking-widest uppercase mb-3" style="color: var(--color-text-secondary); font-family: var(--font-label);">Lo que ofrezco</p>
      <h2 class="text-3xl md:text-4xl font-bold" style="font-family: var(--font-display); color: var(--color-text-primary);">
        Servicios de Pintura
      </h2>
      <p class="mt-4 text-base max-w-xl mx-auto" style="color: var(--color-text-secondary);">
        Trabajos de pintura en la Región Metropolitana y la Cuarta Región de Coquimbo. Calidad profesional garantizada.
      </p>
    </div>

    <!-- Grid servicios -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {servicios.map((s, i) => (
        <div
          class={`flex flex-col gap-4 p-8 rounded-2xl transition-all duration-200 hover:-translate-y-1 hover:shadow-lg reveal delay-${Math.min(i + 1, 5)} ${i === 4 ? 'md:col-span-2 lg:col-span-1' : ''}`}
          style="background-color: var(--color-bg-surface); border: 1px solid var(--color-accent-mid);"
        >
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
            style="background-color: var(--color-bg-dark); color: var(--color-accent-mid);"
          >
            <Fragment set:html={s.icon} />
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2" style="font-family: var(--font-label); color: var(--color-text-primary);">
              {s.titulo}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              {s.descripcion}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
