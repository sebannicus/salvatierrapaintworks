---
const navLinks = [
  { href: '#inicio',     label: 'Inicio' },
  { href: '#servicios',  label: 'Servicios' },
  { href: '#proyectos',  label: 'Proyectos' },
  { href: '#sobre-pablo',label: 'Sobre Pablo' },
  { href: '#contacto',   label: 'Contacto' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
  style="background: rgba(14,23,24,0); backdrop-filter: blur(0px);"
>
  <div class="max-w-7xl mx-auto px-5 h-16 md:h-20 flex items-center justify-between">

    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-3 transition-opacity hover:opacity-90"
      aria-label="Salvatierra PaintWorks — Inicio"
    >
      <div class="w-10 h-10 md:w-11 md:h-11 rounded-full overflow-hidden flex-shrink-0" style="border: 2px solid var(--color-accent);">
        <img
          src="/images/logo-salvatierra.jpeg"
          alt="Salvatierra PaintWorks"
          width="44"
          height="44"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="flex flex-col leading-tight">
        <p class="text-sm font-bold tracking-wide" style="font-family: var(--font-label); color: var(--color-text-light);">Salvatierra</p>
        <p class="text-xs tracking-widest uppercase" style="color: var(--color-accent); font-family: var(--font-label);">PaintWorks</p>
      </div>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-7" aria-label="Navegación principal">
      {navLinks.slice(1).map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium tracking-wide transition-all duration-200 hover:opacity-100 btn-accent-glow"
          style="color: rgba(240,232,212,0.7); font-family: var(--font-label);"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`https://wa.me/56995088570?text=${encodeURIComponent('Hola Salvatierra PaintWorks, vi tu página web y me gustaría cotizar un trabajo de pintura')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-bold btn-wa-glow"
        style="background-color: var(--color-wa-green); color: var(--color-bg-dark); font-family: var(--font-label);"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Cotizar
      </a>
    </nav>

    <!-- Hamburger (mobile) -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg transition-colors"
      style="color: var(--color-text-light);"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="menu-bar block w-6 h-0.5 rounded-full transition-all duration-300" style="background: currentColor;"></span>
      <span class="menu-bar block w-6 h-0.5 rounded-full transition-all duration-300" style="background: currentColor;"></span>
      <span class="menu-bar block w-6 h-0.5 rounded-full transition-all duration-300" style="background: currentColor;"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300"
    style="max-height: 0; background: rgba(14,23,24,0.97); backdrop-filter: blur(20px);"
  >
    <nav class="flex flex-col px-5 pb-6 pt-2 gap-1" aria-label="Menú móvil">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link py-3 text-base font-medium border-b transition-colors duration-200"
          style="color: rgba(240,232,212,0.85); border-color: rgba(166,149,128,0.15); font-family: var(--font-label);"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`https://wa.me/56995088570?text=${encodeURIComponent('Hola Salvatierra PaintWorks, vi tu página web y me gustaría cotizar un trabajo de pintura')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center justify-center gap-3 px-7 py-5 rounded-full text-base font-bold btn-wa-glow"
        style="background-color: var(--color-wa-green); color: var(--color-bg-dark); font-family: var(--font-label);"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Cotizar por WhatsApp
      </a>
    </nav>
  </div>
</header>

<script>
  const header     = document.getElementById('site-header')!;
  const toggle     = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bars       = toggle.querySelectorAll('.menu-bar');
  let   menuOpen   = false;

  // Scroll — bg solidificado
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header.style.background = 'rgba(14,23,24,0.95)';
      header.style.backdropFilter = 'blur(20px)';
      header.style.boxShadow = '0 1px 0 rgba(166,149,128,0.15)';
    } else {
      header.style.background = 'rgba(14,23,24,0)';
      header.style.backdropFilter = 'blur(0px)';
      header.style.boxShadow = 'none';
    }
  }, { passive: true });

  // Hamburger toggle
  toggle.addEventListener('click', () => {
    menuOpen = !menuOpen;
    toggle.setAttribute('aria-expanded', String(menuOpen));
    mobileMenu.style.maxHeight = menuOpen ? `${mobileMenu.scrollHeight}px` : '0';

    // Animate bars to X
    if (menuOpen) {
      (bars[0] as HTMLElement).style.transform = 'translateY(8px) rotate(45deg)';
      (bars[1] as HTMLElement).style.opacity = '0';
      (bars[2] as HTMLElement).style.transform = 'translateY(-8px) rotate(-45deg)';
    } else {
      (bars[0] as HTMLElement).style.transform = '';
      (bars[1] as HTMLElement).style.opacity = '1';
      (bars[2] as HTMLElement).style.transform = '';
    }
  });

  // Close on nav link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      toggle.setAttribute('aria-expanded', 'false');
      mobileMenu.style.maxHeight = '0';
      (bars[0] as HTMLElement).style.transform = '';
      (bars[1] as HTMLElement).style.opacity = '1';
      (bars[2] as HTMLElement).style.transform = '';
    });
  });
</script>
